<Window x:Class="LuchtkanaalCalculator.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Informatie" Height="250" Width="350" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        Background="#FF002262" Topmost="True" ShowInTaskbar="False" Icon="/Resources/VA.ico">
    
    <StackPanel Margin="15" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Digitale Luchtschijf" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Text="Versie 2026.1" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,2"/>
        
        <TextBlock Text="Berekeningen gebaseerd op:" Foreground="#FFCCCCCC" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        <TextBlock Text="Q = v * A * 3600" Foreground="Yellow" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        
        <TextBlock Text="Applicatie gemaakt door AvdH©2026, buy me a coffee" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,10" TextWrapping="Wrap" TextAlignment="Center"/>

        <Button Click="btnKofi_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Support me on Ko-fi">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter />
                </ControlTemplate>
            </Button.Template>
            <Image Source="/Resources/ko-fi.png" Width="80" Height="25" RenderOptions.BitmapScalingMode="HighQuality"/>
        </Button>
    </StackPanel>
</Window>